# Copy to .env and fill in. NEVER commit .env (it holds secrets).

# Cloudflare API token with Zone.DNS edit on the zone for <personal-domain>.
# Used ONLY for the DNS-01 ACME challenge that issues the *.t3.<domain> wildcard
# certificate. No public DNS records are created. See docs/cloudflare.md.
CF_API_TOKEN=

# Base domain; the relay surface lives under t3.<T3_DOMAIN>
# (e.g. relay.t3.example.com, web.t3.example.com, <repo>.t3.example.com).
T3_DOMAIN=example.com

# Comma-separated bearer tokens accepted by the relay API. One per person/device
# so they can be revoked independently. Generate with: openssl rand -hex 32
# See docs/secrets-and-tokens.md.
RELAY_TOKENS=

# Host path to the shared-secret file, bind-mounted (read-only) into the caddy
# container and into every devcontainer. Lets the relay authenticate itself to
# the per-devcontainer servers via the X-Relay-Secret header. Create it with:
#   mkdir -p ~/.config/t3relay && openssl rand -hex 32 > ~/.config/t3relay/secret && chmod 600 ~/.config/t3relay/secret
RELAY_SECRET_FILE=~/.config/t3relay/secret

# Tailscale auth key for the sidecar node (reusable + ephemeral recommended).
# See docs/tailscale.md.
TS_AUTHKEY=
