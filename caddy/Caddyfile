# caddy/Caddyfile — base configuration
#
# This file is the STATIC base config merged by caddy-docker-proxy (CDP) at
# startup (via CADDY_DOCKER_CADDYFILE_PATH). CDP adds routes generated from
# `caddy=` labels on containers, including this relay container, alongside what
# is defined here.
#
# Routing model (see docs/decisions/0003-route-merge-mechanism.md): the
# t3code_relay module does NOT generate per-container routes. Instead it runs a
# background Docker-discovery app (registered by the `t3code_relay` global
# option below) that keeps SQLite fresh, plus two request-time HTTP handlers:
#
#   t3code_relay_proxy  — mounted on wildcard site labels such as
#                         `*.t3.example.com`. Per request it validates the
#                         client Bearer token, resolves the Host to a discovered
#                         container, and reverse-proxies to its server on :3773,
#                         injecting X-Relay-Secret.
#   t3code_relay_api    — mounted on exact relay host labels such as
#                         `relay.t3.example.com`. The relay control-plane API
#                         (environment listing, status, connect) with Bearer auth.
#
# The wildcard and exact relay hostnames are declared on the caddy container's
# own labels in docker-compose.yml. Those same wildcard labels are also the
# relay's source of truth for which tailnet DNS zones to answer.
{
	# Tailnet HTTPS reaches this Caddy server through the relay module's
	# tsnet TCP bridge. Keep client-side transport simple for long-lived
	# WebSocket RPC streams; HTTP/2 multiplexing and HTTP/3 Alt-Svc introduce
	# extra flow-control/retry behavior that has shown up as intermittent
	# tailnet-only socket disconnects under response-stream load.
	servers {
		protocols h1
	}

	# ------------------------------------------------------------------
	# ACME / TLS: DNS-01 challenge via Cloudflare for the wildcard cert.
	#
	# Issuing *.t3.{$T3_DOMAIN} requires DNS-01 (wildcard SANs cannot use
	# HTTP-01). CF_API_TOKEN needs Zone → DNS → Edit on the zone that owns
	# T3_DOMAIN. This single wildcard cert covers relay.t3.*, web.t3.*, and
	# every <repo>.t3.* host. See docs/cloudflare.md.
	# ------------------------------------------------------------------
	acme_dns cloudflare {$CF_API_TOKEN}

	# ------------------------------------------------------------------
	# t3code_relay — registers the relay Caddy app + Docker discovery.
	# Site blocks are provided by caddy-docker-proxy labels; this global option
	# provides the shared runtime config.
	# ------------------------------------------------------------------
	t3code_relay {
		domain_suffix t3.{$T3_DOMAIN}
		relay_host relay.t3.{$T3_DOMAIN}
		db_path /var/lib/t3code-relay/relay.db
		docker_host unix:///var/run/docker.sock
		probe_port 3773
		tokens {$RELAY_TOKENS}
		shared_secret_file /run/secrets/t3relay-secret
		tailscale_hostname {$TAILSCALE_HOSTNAME}
		tailscale_auth_key {$TS_AUTHKEY}
		tailscale_state_dir /var/lib/t3code-relay/tsnet
		ssh_host_key_file /var/lib/t3code-relay/ssh_host_ed25519_key
		ssh_allowed_user vscode
		ssh_backend_port 2222
	}
}
