#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage:
  t3relay expose <port> [--name <name>] [--ttl <seconds>] [--relay-url <url>] [--environment-id <id>]
  t3relay exposures [--relay-url <url>] [--environment-id <id>]
  t3relay unexpose <name> [--relay-url <url>] [--environment-id <id>]

Environment:
  T3RELAY_URL or T3_RELAY_URL     Relay base URL, e.g. https://relay.t3.example.com
  DEVCONTAINER_ID                 Environment id registered with the relay
USAGE
}

die() {
    echo "t3relay: $*" >&2
    exit 1
}

json_string() {
    node -e 'process.stdout.write(JSON.stringify(process.argv[1] ?? ""))' "$1"
}

url_encode() {
    node -e 'process.stdout.write(encodeURIComponent(process.argv[1] ?? ""))' "$1"
}

require_tools() {
    command -v curl >/dev/null 2>&1 || die "curl is required"
    command -v node >/dev/null 2>&1 || die "node is required"
}

load_feature_env() {
    if [ -r /usr/local/etc/t3code-server.env ]; then
        # shellcheck source=/dev/null
        . /usr/local/etc/t3code-server.env
    fi
}

relay_url=""
environment_id=""
secret_path=""
name=""
ttl="3600"

load_feature_env
relay_url="${T3RELAY_URL:-${T3_RELAY_URL:-}}"
environment_id="${DEVCONTAINER_ID:-}"
secret_path="${T3CODE_SECRETPATH:-/run/t3code/relay-secret}"

command_name="${1:-}"
if [ -z "${command_name}" ]; then
    usage
    exit 2
fi
shift

case "${command_name}" in
    expose)
        port="${1:-}"
        [ -n "${port}" ] || die "expose requires a port"
        shift
        ;;
    exposures|unexpose)
        if [ "${command_name}" = "unexpose" ]; then
            name="${1:-}"
            [ -n "${name}" ] || die "unexpose requires a name"
            shift
        fi
        ;;
    -h|--help|help)
        usage
        exit 0
        ;;
    *)
        usage
        exit 2
        ;;
esac

while [ "$#" -gt 0 ]; do
    case "$1" in
        --name)
            [ "$#" -ge 2 ] || die "--name requires a value"
            name="$2"
            shift 2
            ;;
        --ttl)
            [ "$#" -ge 2 ] || die "--ttl requires a value"
            ttl="$2"
            shift 2
            ;;
        --relay-url)
            [ "$#" -ge 2 ] || die "--relay-url requires a value"
            relay_url="$2"
            shift 2
            ;;
        --environment-id)
            [ "$#" -ge 2 ] || die "--environment-id requires a value"
            environment_id="$2"
            shift 2
            ;;
        *)
            die "unknown argument: $1"
            ;;
    esac
done

require_tools

[ -n "${relay_url}" ] || die "set T3RELAY_URL, T3_RELAY_URL, or pass --relay-url"
[ -n "${environment_id}" ] || die "set DEVCONTAINER_ID or pass --environment-id"
[ -r "${secret_path}" ] || die "relay secret is not readable at ${secret_path}"

relay_url="${relay_url%/}"
secret="$(tr -d '\r\n' < "${secret_path}")"
[ -n "${secret}" ] || die "relay secret is empty"
environment_id_path="$(url_encode "${environment_id}")"

case "${command_name}" in
    expose)
        case "${port}" in
            ''|*[!0-9]*) die "port must be numeric" ;;
        esac
        case "${ttl}" in
            ''|*[!0-9]*) die "ttl must be numeric" ;;
        esac
        body="{\"port\":${port},\"ttlSeconds\":${ttl}"
        if [ -n "${name}" ]; then
            body="${body},\"name\":$(json_string "${name}")"
        fi
        body="${body}}"
        response="$(curl -fsS \
            -X POST \
            -H "Content-Type: application/json" \
            -H "X-Relay-Secret: ${secret}" \
            --data "${body}" \
            "${relay_url}/v1/environments/${environment_id_path}/exposures")"
        node -e 'const response = JSON.parse(process.argv[1]); console.log(response.url ?? JSON.stringify(response));' "${response}"
        ;;
    exposures)
        curl -fsS \
            -H "X-Relay-Secret: ${secret}" \
            "${relay_url}/v1/environments/${environment_id_path}/exposures"
        echo
        ;;
    unexpose)
        name_path="$(url_encode "${name}")"
        curl -fsS \
            -X DELETE \
            -H "X-Relay-Secret: ${secret}" \
            "${relay_url}/v1/environments/${environment_id_path}/exposures/${name_path}" >/dev/null
        ;;
esac
